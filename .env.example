# Supabase - obtenha em: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# Google Gemini - obtenha em: https://aistudio.google.com/app/apikey
# IMPORTANTE: Restrinja esta chave por domínio HTTP no Google Cloud Console
VITE_GEMINI_API_KEY=your_gemini_api_key_here
